# ── Google Gemini ─────────────────────────────────────────────
# Ключ Google AI Studio: https://aistudio.google.com/apikey
# Скопируйте этот файл в .env.local и вставьте свой ключ.
GEMINI_API_KEY=

# Модель для распознавания PDF-отчётов (извлечение данных).
# По умолчанию — самая точная и быстрая из проверенных.
GEMINI_MODEL_EXTRACT=gemini-3.5-flash

# Модель для чата с менеджером (вопросы по процессу и по отчёту).
GEMINI_MODEL_CHAT=gemini-3.5-flash

# ── Бизнес-параметры (в рублях) ───────────────────────────────
# Стоимость услуги «Банкротство физлица» под ключ.
BANKRUPTCY_COST=200000
# Стоимость услуги «Реструктуризация долга».
RESTRUCTURING_COST=150000
